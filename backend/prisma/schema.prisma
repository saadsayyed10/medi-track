generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model patient {
  id                     String   @id @default(uuid())
  name                   String
  email                  String   @unique
  password               String
  age                    String
  allergies              String
  allergy_keywords       String[]
  health_issues          String?
  health_issues_keywords String[]
  created_at             DateTime @default(now())
}
